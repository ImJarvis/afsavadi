---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Air Force School, Avadi - Official Website. Committed to providing quality education, instilling discipline, and nurturing future leaders." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/images/logo.jpg" />
		
        {/* Open Graph / Social SEO */}
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://afschoolavadi.com/" />
        <meta property="og:title" content={`${title} | Air Force School Avadi`} />
        <meta property="og:description" content="Air Force School, Avadi - Committed to providing quality education, instilling discipline, and nurturing future leaders." />
        <meta property="og:image" content="/images/logo.jpg" />
        
        {/* Twitter */}
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:title" content={`${title} | Air Force School Avadi`} />
        <meta property="twitter:description" content="Air Force School, Avadi - Committed to providing quality education, instilling discipline, and nurturing future leaders." />
        <meta property="twitter:image" content="/images/logo.jpg" />

		<meta name="generator" content={Astro.generator} />
		<title>{title} | Air Force School Avadi</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="flex flex-col min-h-screen">
        <Header />
		<main class="flex-grow">
			<slot />
		</main>
        <Footer />
	</body>
</html>
