---
// Header Component
---
<header class="w-full bg-white shadow-md z-50 sticky top-0">

  {/* Announcement Bar */}
  <div class="bg-amber-600 py-1.5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      {/* Left: Info Links */}
      <div class="flex items-center space-x-4 text-xs text-white">
        <a href="/neet-coaching" class="flex items-center hover:text-amber-200 transition-colors font-medium">
          <svg class="w-3.5 h-3.5 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          NEET &amp; JEE Preparation
        </a>
        <span class="text-amber-300 hidden sm:inline">|</span>
        <a href="/admission#class-xi" class="hidden sm:flex items-center hover:text-amber-200 transition-colors font-medium">
          <svg class="w-3.5 h-3.5 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
          <span class="text-amber-200 font-bold animate-pulse mr-1">★</span> Admissions Open for Class XI
        </a>
      </div>
      {/* Right: Action Buttons */}
      <div class="flex items-center space-x-2">
        <a href="https://chaloschools.in/web/webportal/#/sign-in" target="_blank" rel="noopener noreferrer"
           class="bg-white text-amber-700 hover:bg-amber-100 font-semibold text-xs px-3 py-1 rounded-full transition-colors flex items-center">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          Parent Portal
        </a>
        <a href="https://afschoolavadi.com/Documents/STUDENT%20ADMISSION%20FORM.pdf" target="_blank" rel="noopener noreferrer"
           class="bg-amber-800 text-white hover:bg-amber-900 font-semibold text-xs px-3 py-1 rounded-full transition-colors flex items-center">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Admission Form
        </a>
      </div>
    </div>
  </div>

  {/* Tier 2: Identity Bar (White Background) */}
  <div class="py-3 md:py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      
      {/* Crest & Title */}
      <div class="flex items-center space-x-3 md:space-x-5">
        <a href="/" class="flex-shrink-0">
          <div class="w-16 h-16 md:w-20 md:h-20 bg-white rounded-full border-2 border-secondary flex items-center justify-center overflow-hidden shadow-md flex-shrink-0">
            <img src="/images/logo.png" alt="Air Force School Avadi Crest" class="w-full h-full object-contain p-1" />
          </div>
        </a>
        
        <div class="flex flex-col">
          <a href="/">
             <h1 class="text-xl md:text-3xl lg:text-4xl font-extrabold text-primary uppercase tracking-tight leading-none mb-1">
               Air Force School <span class="text-gray-600 font-medium">Avadi</span>
             </h1>
          </a>
          <p class="text-sm md:text-base text-gray-500 italic font-medium">"We Educate the Minds to Think and Conquer"</p>
        </div>
      </div>

      {/* Search Bar & CBSE Logo - Hidden on very small screens */}
      <div class="hidden md:flex flex-shrink-0 items-center space-x-6">
        <div class="relative group z-50">
          <input type="text" id="search-input" placeholder="Search..." autocomplete="off" class="w-48 lg:w-64 py-2 pl-4 pr-10 rounded-full border border-gray-300 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-all group-hover:border-primary" />
          <button class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </button>
          
          {/* Search Results Dropdown */}
          <div id="search-results" class="absolute top-full right-0 mt-2 w-72 bg-white rounded-lg shadow-xl border border-gray-100 hidden max-h-96 overflow-y-auto z-50">
            <ul id="search-results-list" class="py-2">
              {/* Results will be injected here via JS */}
            </ul>
          </div>
        </div>
        <div class="w-14 h-14 md:w-16 md:h-16 rounded-full border border-gray-200 flex items-center justify-center bg-white shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="w-full h-full p-1"><circle cx="50" cy="50" r="45" fill="none" stroke="#083a6b" stroke-width="3"/><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-size="22" font-weight="bold" fill="#083a6b">CBSE</text></svg>
        </div>
      </div>

      {/* Mobile Menu Button */}
      <div class="lg:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-primary hover:text-accent focus:outline-none p-2 border border-gray-200 rounded">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  {/* Tier 3: Navigation Bar (Primary Blue) */}
  <div class="hidden lg:block bg-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex space-x-1 items-stretch">
        <a href="/" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors">Home</a>

        {/* About Us Dropdown */}
        <div class="relative group">
          <a href="/about" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors flex items-center gap-1 h-full">
            About Us
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <div class="absolute top-full left-0 hidden group-hover:block bg-white shadow-lg border border-gray-200 z-50 min-w-48 border-t-2 border-t-secondary">
            <a href="/about" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">About the School</a>
            <a href="/about#leadership" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">Leadership Team</a>
            <a href="/mpd" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">Mandatory Disclosure</a>
          </div>
        </div>

        {/* Academics Dropdown */}
        <div class="relative group">
          <a href="/academics" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors flex items-center gap-1 h-full">
            Academics
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <div class="absolute top-full left-0 hidden group-hover:block bg-white shadow-lg border border-gray-200 z-50 min-w-52 border-t-2 border-t-secondary">
            <a href="/academics" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">Curriculum Overview</a>
            <a href="/academics#calendar" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">Academic Calendar</a>
            <a href="/academics#papers" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">Sample Question Papers</a>
            <a href="/achievements#results" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">Board Results</a>
            <a href="/neet-coaching" class="block px-4 py-3 text-sm text-primary hover:bg-blue-50 border-l-4 border-transparent hover:border-secondary transition-all">NEET &amp; JEE Coaching</a>
          </div>
        </div>

        <a href="/admission" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors">Admission</a>
        <a href="/facilities" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors">Infrastructure</a>
        <a href="/achievements" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors">Achievements</a>
        <a href="/gallery" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors">Gallery</a>
        <a href="/notices" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors">Notices</a>
        <a href="/contact" class="text-white hover:bg-primary-dark hover:text-accent px-4 py-3 text-sm font-semibold uppercase transition-colors">Contact Us</a>
      </nav>
    </div>
  </div>

  {/* Mobile Navigation Menu */}
  <div id="mobile-menu" class="hidden lg:hidden bg-primary border-t border-primary-dark">
    <div class="flex flex-col px-4 pt-2 pb-4 space-y-1">
      <a href="/" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Home</a>

      {/* About Us with sub-items */}
      <a href="/about" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">About Us</a>
      <div class="pl-4 space-y-1 border-l-2 border-primary-dark ml-3">
        <a href="/about" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">About the School</a>
        <a href="/about#leadership" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">Leadership Team</a>
        <a href="/mpd" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">Mandatory Disclosure</a>
      </div>

      {/* Academics with sub-items */}
      <a href="/academics" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Academics</a>
      <div class="pl-4 space-y-1 border-l-2 border-primary-dark ml-3">
        <a href="/academics" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">Curriculum Overview</a>
        <a href="/academics#calendar" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">Academic Calendar</a>
        <a href="/academics#papers" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">Sample Question Papers</a>
        <a href="/achievements#results" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">Board Results</a>
        <a href="/neet-coaching" class="text-gray-200 hover:text-white block px-3 py-1.5 text-sm">NEET &amp; JEE Coaching</a>
      </div>

      <a href="/admission" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Admission</a>
      <a href="/facilities" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Infrastructure</a>
      <a href="/achievements" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Achievements</a>
      <a href="/gallery" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Gallery</a>
      <a href="/notices" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Notices</a>
      <a href="/contact" class="text-white hover:bg-primary-dark hover:text-accent block px-3 py-2 rounded-md text-base font-medium">Contact Us</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if(btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
  }

  // Search functionality
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const searchResultsList = document.getElementById('search-results-list');

  const pages = [
    { title: "Home", url: "/", desc: "Air Force School Avadi Homepage" },
    { title: "About Us", url: "/about", desc: "History, Vision, Mission, and Leadership" },
    { title: "Academics", url: "/academics", desc: "Curriculum, Subjects, and Academic Calendar" },
    { title: "Admission", url: "/admission", desc: "Admission Guidelines, Fee Structure, and Forms" },
    { title: "Facilities", url: "/facilities", desc: "Infrastructure, Labs, Library, and Sports" },
    { title: "Gallery", url: "/gallery", desc: "Photos of Campus Life and Events" },
    { title: "Achievements", url: "/achievements", desc: "Awards, Honors, and Board Results" },
    { title: "Notices", url: "/notices", desc: "Notice Board, Circulars, and News" },
    { title: "Contact Us", url: "/contact", desc: "Location, Phone, Email, and Map" },
    { title: "Mandatory Public Disclosure", url: "/mpd", desc: "CBSE MPD Details and Documents" },
    { title: "NEET & JEE Coaching", url: "/neet-coaching", desc: "Preparation for competitive exams" }
  ];

  if (searchInput && searchResults && searchResultsList) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      
      if (query.length < 2) {
        searchResults.classList.add('hidden');
        return;
      }

      const results = pages.filter(p => 
        p.title.toLowerCase().includes(query) || 
        p.desc.toLowerCase().includes(query)
      );

      searchResultsList.innerHTML = '';

      if (results.length > 0) {
        results.forEach(result => {
          const li = document.createElement('li');
          li.innerHTML = `
            <a href="${result.url}" class="block px-4 py-2 hover:bg-gray-50 border-b border-gray-100 last:border-0 transition-colors">
              <div class="font-semibold text-primary text-sm">${result.title}</div>
              <div class="text-xs text-gray-500 truncate">${result.desc}</div>
            </a>
          `;
          searchResultsList.appendChild(li);
        });
      } else {
        searchResultsList.innerHTML = `
          <li class="px-4 py-3 text-sm text-gray-500 text-center italic">
            No results found for "${e.target.value}"
          </li>
        `;
      }
      
      searchResults.classList.remove('hidden');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });
  }
</script>
