---
interface Props {
  items: Array<{ label: string; href?: string }>;
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="bg-gray-100 border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
    <ol class="flex items-center space-x-2 text-sm">
      <li>
        <a href="/" class="text-primary hover:text-accent transition-colors font-medium flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Home
        </a>
      </li>
      {items.map((item, i) => (
        <>
          <li><span class="text-gray-400">›</span></li>
          <li>
            {item.href && i < items.length - 1 ? (
              <a href={item.href} class="text-primary hover:text-accent transition-colors font-medium">{item.label}</a>
            ) : (
              <span class="text-gray-500 font-semibold">{item.label}</span>
            )}
          </li>
        </>
      ))}
    </ol>
  </div>
</nav>
