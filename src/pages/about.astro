---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="About Us">
  <div class="bg-primary text-white py-16 border-b-4 border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center">
      <div class="w-16 h-16 bg-white rounded-full p-1 mr-4 hidden md:block">
         <img src="/images/logo.jpg" alt="School Crest" class="w-full h-full object-contain rounded-full" />
      </div>
      <div>
        <h1 class="text-3xl md:text-5xl font-extrabold uppercase tracking-wide">About Our School</h1>
        <p class="text-gray-300 mt-2 font-medium">Nurturing Excellence Since 1948</p>
      </div>
    </div>
  </div>

  <Breadcrumb items={[{ label: 'About Our School' }]} />

  <section class="py-12 md:py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      <div class="lg:col-span-2 space-y-10 text-gray-700 leading-relaxed">
        
        {/* Featured Campus Image */}
        <div class="rounded-lg overflow-hidden shadow-md border border-gray-200">
          <img src="/Infrastructure/Infra25/School Building/1.jpg" onerror="this.src='/images/HonepageFirstphoto.jpg'" alt="School Campus" class="w-full h-64 md:h-96 object-cover" />
        </div>

        <div>
          <h2 class="text-3xl font-bold text-primary border-b-2 border-secondary pb-2 mb-6 uppercase inline-block">History &amp; Overview</h2>
          <p class="mb-4 text-justify">
            Established in <strong>1948</strong>, Air Force School Avadi has a rich history of nurturing young minds. We are permanently affiliated with the Central Board of Secondary Education (CBSE Affiliation No: 1980003) and managed by the IAF Educational and Cultural Society.
          </p>
          <p class="mb-4 text-justify">
            The school aims to promote education, culture, and sports among the children of Air Force Personnel and the local community. The school runs classes from LKG to XII with Science and Commerce streams at the Senior Secondary level.
          </p>
        </div>

        {/* Vision & Mission */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-blue-50 p-6 rounded-lg border border-blue-100 shadow-sm">
            <div class="flex items-center mb-3">
              <svg class="w-8 h-8 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
              <h3 class="text-xl font-bold text-primary uppercase">Our Vision</h3>
            </div>
            <p class="text-sm text-justify">To be the premier educational institution that cultivates intellectual curiosity, personal growth, and ethical leadership.</p>
          </div>
          <div class="bg-yellow-50 p-6 rounded-lg border border-yellow-100 shadow-sm">
            <div class="flex items-center mb-3">
              <svg class="w-8 h-8 text-secondary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <h3 class="text-xl font-bold text-primary uppercase">Our Mission</h3>
            </div>
            <p class="text-sm text-justify">To provide quality education in a disciplined and nurturing environment, instilling core values of integrity and patriotism.</p>
          </div>
        </div>

        {/* CBSE Information */}
        <div>
          <h2 class="text-3xl font-bold text-primary border-b-2 border-secondary pb-2 mb-6 uppercase inline-block">CBSE Affiliation Details</h2>
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
            <table class="w-full text-sm">
              <tbody>
                {[
                  ['Year of Establishment', '1948'],
                  ['Affiliation No.', '1980003'],
                  ['Status of Affiliation', 'PERMANENT'],
                  ['Trust / Society Name', 'IAF Educational and Cultural Society'],
                  ['Registered under Section 25 of Companies Act', 'YES'],
                  ['Trust Registration', 'PERMANENT'],
                  ['Academic Session Period', '01 April to 31 March'],
                  ['Vacation Period', '08 May 2025 to 20 June 2025'],
                ].map(([field, value], i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    <td class="px-5 py-3 font-semibold text-gray-700 w-2/5 border-r border-gray-100">{field}</td>
                    <td class="px-5 py-3 text-gray-800">{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {/* CBSE Approval Letter Download */}
          <a
            href="https://afschoolavadi.com/Documents/Documents%20as%20Per%20CBSE.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-blue-900 transition-colors shadow-md"
          >
            <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download CBSE Approval Letter
          </a>
        </div>

        {/* History Timeline */}
        <div>
          <h2 class="text-3xl font-bold text-primary border-b-2 border-secondary pb-2 mb-8 uppercase inline-block">Our Journey</h2>
          <div class="relative border-l-4 border-gray-200 ml-4 space-y-8 pb-4">
            <div class="relative pl-8">
              <div class="absolute -left-[14px] top-1 w-6 h-6 rounded-full bg-primary border-4 border-white shadow"></div>
              <h3 class="font-bold text-primary text-lg">1948</h3>
              <p class="text-gray-600 font-medium">Foundation of Air Force School Avadi under the aegis of IAF Educational and Cultural Society.</p>
            </div>
            <div class="relative pl-8">
              <div class="absolute -left-[14px] top-1 w-6 h-6 rounded-full bg-secondary border-4 border-white shadow"></div>
              <h3 class="font-bold text-primary text-lg">CBSE Permanent Affiliation</h3>
              <p class="text-gray-600 font-medium">Secured permanent affiliation with the Central Board of Secondary Education (No. 1980003).</p>
            </div>
            <div class="relative pl-8">
              <div class="absolute -left-[14px] top-1 w-6 h-6 rounded-full bg-accent border-4 border-white shadow"></div>
              <h3 class="font-bold text-primary text-lg">Senior Secondary Status</h3>
              <p class="text-gray-600 font-medium">Upgraded to Class XII with Science and Commerce streams, becoming a full Senior Secondary school.</p>
            </div>
            <div class="relative pl-8">
              <div class="absolute -left-[14px] top-1 w-6 h-6 rounded-full bg-primary border-4 border-white shadow"></div>
              <h3 class="font-bold text-primary text-lg">Best AF School Award — Multiple Times</h3>
              <p class="text-gray-600 font-medium">Recognised as the Best Air Force School in IAF, a distinction won multiple times, reflecting sustained excellence.</p>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-bold text-primary border-b-2 border-secondary pb-2 mb-6 uppercase inline-block">Campus Details</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-gray-50 border border-gray-200 p-4 rounded-lg text-center shadow-sm">
              <span class="block text-3xl font-bold text-secondary mb-1">1.92</span>
              <span class="block text-sm font-semibold text-gray-500 uppercase">Acres Total Area</span>
              <span class="block text-xs text-gray-400">(7776.77 Sq. mtrs)</span>
            </div>
            <div class="bg-gray-50 border border-gray-200 p-4 rounded-lg text-center shadow-sm">
              <span class="block text-3xl font-bold text-secondary mb-1">1072</span>
              <span class="block text-sm font-semibold text-gray-500 uppercase">Sq. Mtrs Built-up</span>
              <span class="block text-xs text-gray-400">Classrooms &amp; Labs</span>
            </div>
            <div class="bg-gray-50 border border-gray-200 p-4 rounded-lg text-center shadow-sm">
              <span class="block text-3xl font-bold text-secondary mb-1">6704</span>
              <span class="block text-sm font-semibold text-gray-500 uppercase">Sq. Mtrs Playground</span>
              <span class="block text-xs text-gray-400">Sports Facilities</span>
            </div>
          </div>
        </div>

        {/* School Management Committee */}
        <div id="smc">
          <h2 class="text-3xl font-bold text-primary border-b-2 border-secondary pb-2 mb-6 uppercase inline-block">School Management Committee</h2>
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-primary text-white">
                  <th class="px-5 py-3 text-left font-semibold">Name</th>
                  <th class="px-5 py-3 text-left font-semibold">Designation / Role</th>
                </tr>
              </thead>
              <tbody>
                {[
                  ['Air Cmde Pradeep Sharma VSM', 'Chairman'],
                  ['Flt Lt Akshaya Sree NR', 'Executive Director'],
                  ['Mrs Rakhee Nair', 'Principal'],
                  ['GpCapt M Gopinath', 'C Adm O'],
                  ['Wg Cdr VS Rajesh', 'SAO'],
                  ['Sqn Ldr S Pradhan', 'Stn Wks O'],
                  ['Sqn Ldr Anupama Singh', 'SMO'],
                  ['MWO Madhu', 'Stn MWO'],
                  ['Lt Col Alkesh Tiwari', 'GE'],
                  ['Sgt Vickey Sigroha', 'School Manager'],
                  ['Sgt Bhupendra Singh', 'Parent Representative'],
                  ['Mr Suresh Kumar S', 'Parent Representative'],
                  ['Mrs Sharmila', 'Teacher Representative'],
                ].map(([name, role], i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    <td class="px-5 py-3 font-semibold text-gray-800 border-r border-gray-100">{name}</td>
                    <td class="px-5 py-3 text-gray-700">{role}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* Grievance & Support */}
        <div id="grievance">
          <h2 class="text-3xl font-bold text-primary border-b-2 border-secondary pb-2 mb-6 uppercase inline-block">Grievance &amp; Support</h2>
          <div class="bg-blue-50 border-l-4 border-secondary rounded-r-xl p-6 shadow-sm space-y-4">
            <div>
              <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Grievance / Redressal Officer</p>
              <p class="font-bold text-primary text-lg">Flt Lt Akshaya Sree NR</p>
              <p class="text-sm text-gray-600">Executive Director</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:edafschoolavadi@gmail.com" class="text-primary hover:underline font-medium">edafschoolavadi@gmail.com</a>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href="tel:9600021855" class="text-primary hover:underline font-medium">9600021855</a>
              </div>
            </div>
            <div class="border-t border-blue-200 pt-4">
              <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Sexual Harassment Committee</p>
              <p class="text-sm text-gray-700 font-medium">Mrs. Rakhee Nair &nbsp;|&nbsp; Mrs. Latha</p>
            </div>
          </div>
        </div>

      </div>

      <div class="space-y-8">

        {/* Principal's Desk */}
        <div class="bg-gradient-to-br from-primary to-primary-dark p-6 rounded-lg border-t-4 border-secondary text-white shadow-md">
          <h3 class="text-xl font-bold mb-4 uppercase tracking-wide border-b border-white/20 pb-2 flex items-center">
            <svg class="w-5 h-5 mr-2 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Principal's Desk
          </h3>
          <div class="flex items-center space-x-4 mb-4">
            <div class="w-16 h-16 bg-white/20 rounded-full border-2 border-secondary flex items-center justify-center shrink-0">
              <svg class="w-8 h-8 text-white/70" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <p class="font-bold text-lg">Mrs. Rakhee Nair</p>
              <p class="text-secondary text-sm font-semibold uppercase tracking-wider">Principal</p>
            </div>
          </div>
          <blockquote class="border-l-4 border-secondary pl-4 italic text-white/90 text-sm leading-relaxed">
            "Education is not just the filling of a pail, but the lighting of a fire. At Air Force School Avadi, we strive to ignite that spark of curiosity, discipline, and excellence in every student."
          </blockquote>
        </div>

        {/* Chairman's Details */}
        <div id="leadership" class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
          <div class="bg-primary px-5 py-3">
            <h3 class="text-white font-bold text-base uppercase tracking-wide">Chairman</h3>
          </div>
          <div class="p-5 space-y-3">
            <div class="flex items-center space-x-4">
              <div class="w-14 h-14 bg-blue-100 rounded-full flex-shrink-0 border-2 border-secondary flex items-center justify-center">
                <svg class="w-7 h-7 text-primary/60" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
              </div>
              <div>
                <p class="font-bold text-primary text-base leading-tight">Air Cmde Pradeep Sharma VSM</p>
                <p class="text-secondary text-xs font-bold uppercase tracking-wider mt-0.5">Chairman, SMC</p>
              </div>
            </div>
            <div class="text-sm text-gray-600 space-y-1.5 pt-1 border-t border-gray-100">
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-secondary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Air Force Station Avadi, Chennai - 600055</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span>26842045 ext. 7200</span>
              </div>
            </div>
          </div>
        </div>

        {/* Quick Facts */}
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 shadow-sm">
          <h3 class="text-xl font-bold text-primary mb-4 uppercase border-b-2 border-secondary inline-block pb-1">Quick Facts</h3>
          <ul class="space-y-4 text-sm">
            <li class="flex flex-col border-b border-gray-100 pb-2">
              <span class="text-gray-500 font-semibold uppercase text-xs">Affiliation</span>
              <span class="font-bold text-dark">CBSE (No. 1980003)</span>
            </li>
            <li class="flex flex-col border-b border-gray-100 pb-2">
              <span class="text-gray-500 font-semibold uppercase text-xs">School Code</span>
              <span class="font-bold text-dark">56353</span>
            </li>
            <li class="flex flex-col border-b border-gray-100 pb-2">
              <span class="text-gray-500 font-semibold uppercase text-xs">Classes</span>
              <span class="font-bold text-dark">LKG to XII</span>
            </li>
            <li class="flex flex-col border-b border-gray-100 pb-2">
              <span class="text-gray-500 font-semibold uppercase text-xs">Established</span>
              <span class="font-bold text-dark">1948</span>
            </li>
            <li class="flex flex-col">
              <span class="text-gray-500 font-semibold uppercase text-xs">Streams Available (XI &amp; XII)</span>
              <span class="font-bold text-dark">Science &amp; Commerce</span>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>
</Layout>
