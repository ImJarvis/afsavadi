---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admission">
  <div class="bg-primary text-white py-16 border-b-4 border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-extrabold uppercase tracking-wide">Admissions</h1>
      <p class="text-gray-300 mt-2 font-medium">Procedures, Forms, and Fee Structure</p>
    </div>
  </div>

  {/* Class XI Admissions Open Banner */}
  <section id="class-xi" class="py-8 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-gradient-to-r from-secondary to-amber-400 rounded-xl shadow-lg px-6 py-8 md:px-10 flex flex-col md:flex-row items-center gap-6 border-4 border-amber-300">
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary animate-pulse"></span>
          <span class="text-primary text-xs font-extrabold uppercase tracking-widest">Now Open</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-extrabold text-primary uppercase tracking-tight leading-tight mb-1">
          Admissions Open for Class XI
        </h2>
        <p class="text-primary font-medium opacity-80">
          Applications accepted for Class XI Science / Commerce streams. Limited seats available — apply early.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0 w-full md:w-auto">
        <a
          href="https://afschoolavadi.com/Documents/STUDENT%20ADMISSION%20FORM.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center bg-primary hover:bg-blue-900 text-white font-bold uppercase text-sm px-5 py-3 rounded-lg shadow-md hover:shadow-lg transition-all group"
        >
          <svg class="w-4 h-4 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Download Application Form
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-white hover:bg-gray-100 text-primary font-bold uppercase text-sm px-5 py-3 rounded-lg shadow-md hover:shadow-lg transition-all border-2 border-primary group"
        >
          <svg class="w-4 h-4 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Contact Admissions Office
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    {/* Admission Notice Banner */}
    <div class="mb-12">
      <div class="bg-yellow-50 border-l-4 border-secondary p-6 rounded-r-lg shadow-sm">
        <div class="flex flex-col md:flex-row items-center gap-6">
          <div class="flex-1">
            <h2 class="text-2xl font-bold text-primary mb-2 uppercase flex items-center">
              <svg class="w-6 h-6 mr-2 text-secondary animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
              Admission Notice (Class IX)
            </h2>
            <p class="text-gray-700 font-medium">Admissions for Class IX are now open for the upcoming academic session. Limited seats available. Please refer to the official notice for eligibility and deadlines.</p>
          </div>
          <div class="w-full md:w-1/3 shrink-0">
             <a href="/images/Admission_IX.jpg" target="_blank" class="block border border-gray-300 rounded overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
               <img src="/images/Admission_IX.jpg" alt="Class IX Admission Notice" class="w-full h-auto group-hover:scale-105 transition-transform duration-300" />
               <div class="bg-white p-2 text-center text-xs font-bold text-primary uppercase border-t border-gray-200 group-hover:bg-gray-50 transition-colors">View Notice</div>
             </a>
          </div>
        </div>
      </div>
    </div>

    {/* Age Criteria Table */}
    <div class="mb-12 bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <div class="bg-primary text-white p-4">
        <h2 class="text-xl font-bold uppercase tracking-wide">Age Criteria for Admission</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-100 text-primary uppercase text-xs tracking-wide border-b-2 border-gray-300">
              <th class="p-3 text-left">Class</th>
              <th class="p-3 text-left">Age Requirement (as on 31st March)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="hover:bg-blue-50 transition-colors">
              <td class="p-3 font-bold text-primary">Pre-KG</td>
              <td class="p-3 text-gray-700">Must have completed <strong>3 years</strong> of age</td>
            </tr>
            <tr class="hover:bg-blue-50 transition-colors">
              <td class="p-3 font-bold text-primary">LKG</td>
              <td class="p-3 text-gray-700">Must have completed <strong>4 years</strong> of age</td>
            </tr>
            <tr class="hover:bg-blue-50 transition-colors">
              <td class="p-3 font-bold text-primary">Class I</td>
              <td class="p-3 text-gray-700">Must have completed <strong>6 years</strong> of age</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="p-4 bg-yellow-50 border-t border-yellow-200 text-sm text-gray-700 space-y-1">
        <p>&#9432; UKG students must seek <strong>fresh admission</strong> to Class I — automatic promotion is not applicable.</p>
        <p>&#9432; Academic Session runs from <strong>1 April to 31 March</strong>. All fees are to be paid in advance.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
      
      {/* Admission Procedure */}
      <div class="space-y-8">
        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-200">
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 uppercase inline-block">Procedure</h2>
          
          <p class="text-gray-700 mb-6 leading-relaxed text-justify">
            Admissions to Air Force School Avadi are conducted in accordance with the guidelines set by the IAF Educational and Cultural Society and CBSE norms. Priority is strictly given to children of Air Force Personnel, followed by other defense and civilian categories subject to the availability of seats.
          </p>
  
          <h3 class="text-xl font-bold text-dark mb-4 uppercase">Eligibility & Documents</h3>
          <ul class="list-disc pl-5 space-y-3 text-gray-700 font-medium">
            <li><strong class="text-primary">Age Limit:</strong> Must meet the minimum age criteria set by CBSE for the respective classes as of 1st April of the academic year.</li>
            <li><strong class="text-primary">Birth Certificate:</strong> Issued by Municipal Corporation / Competent Authority.</li>
            <li><strong class="text-primary">Transfer Certificate:</strong> From the previous school (countersigned by proper authority if required).</li>
            <li><strong class="text-primary">Aadhaar Card:</strong> Student's Aadhaar card copy.</li>
            <li><strong class="text-primary">Service Certificate:</strong> Mandatory for Defense Personnel.</li>
          </ul>
        </div>
        
        {/* Action Cards */}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="/documents/STUDENT_ADMISSION_FORM.pdf" target="_blank" class="bg-secondary hover:bg-secondary-hover text-primary p-6 rounded-lg shadow-md text-center transition-colors border-2 border-transparent hover:border-primary group">
            <svg class="w-12 h-12 mx-auto mb-4 text-primary group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <h4 class="font-bold uppercase text-lg">Download Form</h4>
            <p class="text-sm font-medium mt-1">Admission Application</p>
          </a>
          
          <a href="https://www.onlinesbi.sbi/sbicollect/icollecthome.htm" target="_blank" class="bg-primary hover:bg-primary-dark text-white p-6 rounded-lg shadow-md text-center transition-colors border-2 border-transparent hover:border-secondary group">
            <svg class="w-12 h-12 mx-auto mb-4 text-secondary group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <h4 class="font-bold uppercase text-lg">Pay Fee Online</h4>
            <p class="text-sm font-medium mt-1 text-gray-300">SBI Collect Portal</p>
          </a>
        </div>
      </div>

      {/* Side Content */}
      <div class="space-y-8">
        
        {/* Admission Contacts */}
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <div class="bg-gray-100 p-4 border-b border-gray-200">
             <h3 class="font-bold text-primary uppercase text-center">Admission Enquiries</h3>
          </div>
          <div class="p-4">
             <img src="/images/Admission_Contacts.png" alt="Admission Contacts" class="w-full h-auto rounded" onerror="this.style.display='none'" />
             <div class="text-center mt-4">
               <p class="text-sm text-gray-600">For any admission related queries, please contact the numbers listed during office hours.</p>
             </div>
          </div>
        </div>

        {/* Fee Structure */}
        <div class="bg-white border-2 border-primary rounded-lg shadow-md overflow-hidden">
          <div class="bg-primary text-white p-4 text-center">
             <h3 class="text-xl font-bold uppercase tracking-wide">Fee Structure 2025-26</h3>
          </div>
          <div class="p-4 bg-gray-50">
             <a href="/images/Fee Structure_25-26.jpg" target="_blank" class="block group">
               <img src="/images/Fee Structure_25-26.jpg" alt="Fee Structure 2025-26" class="w-full h-auto border border-gray-300 shadow-sm group-hover:shadow-md transition-shadow" />
               <div class="mt-4 text-center">
                 <span class="inline-block text-primary font-bold underline hover:text-accent transition-colors">Click to Enlarge</span>
               </div>
             </a>
          </div>
        </div>
      </div>
    </div>

    {/* TC Information Section */}
    <div class="mt-8 bg-white border border-gray-200 p-8 rounded-lg shadow-sm">
      <h2 class="text-2xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 uppercase inline-block">Transfer Certificate (TC)</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <div>
          <p class="text-gray-700 mb-4 leading-relaxed text-justify">
            Parents seeking a Transfer Certificate for their ward must submit a written application to the Principal at least one month in advance. The TC will be issued only after all dues have been cleared.
          </p>
          <p class="text-gray-700 leading-relaxed text-justify">
            Below is the standard format for the Transfer Certificate issued by the school, and an example of a completed certificate for reference.
          </p>
          <h3 class="text-lg font-bold text-primary mt-5 mb-3 uppercase">TC Rules</h3>
          <ol class="list-decimal pl-5 space-y-2 text-sm text-gray-700">
            <li>TC will be issued <strong>only after all dues are cleared</strong> and all library books are returned.</li>
            <li>TC will be issued only <strong>7 working days</strong> after the application is submitted.</li>
            <li>Students withdrawing at the end of a session must <strong>apply for TC in January</strong>.</li>
          </ol>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <a href="/images/TC_Format.jpg" target="_blank" class="block group border border-gray-200 rounded p-2 hover:border-primary transition-colors text-center">
             <img src="/images/TC_Format.jpg" alt="TC Format Blank" class="w-full h-48 object-contain mb-2 bg-gray-50" />
             <span class="text-sm font-bold text-primary uppercase">Blank Format</span>
          </a>
          <a href="/images/TC.jpg" target="_blank" class="block group border border-gray-200 rounded p-2 hover:border-primary transition-colors text-center">
             <img src="/images/TC.jpg" alt="TC Sample" class="w-full h-48 object-contain mb-2 bg-gray-50" />
             <span class="text-sm font-bold text-primary uppercase">Sample TC</span>
          </a>
        </div>
      </div>
    </div>

    {/* Caution Money Refund */}
    <div class="mt-8 bg-white border border-gray-200 p-8 rounded-lg shadow-sm">
      <h2 class="text-2xl font-bold text-primary mb-4 border-b-2 border-secondary pb-2 uppercase inline-block">Caution Money Refund</h2>
      <ol class="list-decimal pl-5 space-y-2 text-sm text-gray-700">
        <li>The <strong>original receipt</strong> must be produced at the time of claiming the caution money refund.</li>
        <li>The amount must be collected <strong>within one month</strong> after the TC is issued. After this period, the amount will be <strong>forfeited</strong>.</li>
      </ol>
    </div>

    {/* General Rules */}
    <div class="mt-8 bg-white border border-gray-200 p-8 rounded-lg shadow-sm">
      <h2 class="text-2xl font-bold text-primary mb-4 border-b-2 border-secondary pb-2 uppercase inline-block">General Rules</h2>
      <ol class="list-decimal pl-5 space-y-3 text-sm text-gray-700">
        <li>Students are responsible for their <strong>behaviour both inside and outside</strong> the school premises.</li>
        <li>A minimum of <strong>80% attendance</strong> is required to be eligible for Annual Examinations. A medical certificate must be produced in case of illness-related absences.</li>
        <li>Students who fail consecutively <strong>twice in the same class</strong> may be asked to leave the school.</li>
        <li>Expulsion may follow instances of disobedience, mischief, or <strong>examination malpractices</strong>.</li>
      </ol>
    </div>

  </section>
</Layout>
