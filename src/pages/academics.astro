---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Academics">
  <div class="bg-primary text-white py-16 border-b-4 border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-extrabold uppercase tracking-wide">Academics</h1>
      <p class="text-gray-300 mt-2 font-medium">Curriculum, Streams, Academic Calendar & Resources</p>
    </div>
  </div>

  <Breadcrumb items={[{ label: 'Academics' }]} />

  {/* Medium of Instruction Card */}
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
    <div class="bg-white shadow-sm rounded-lg border-l-4 border-secondary p-6">
      <h2 class="text-2xl font-bold text-primary mb-4 uppercase">Medium of Instruction</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-gray-700 text-sm leading-relaxed">
        <ul class="space-y-2">
          <li><span class="font-semibold text-primary">Medium:</span> English is the medium of instruction.</li>
          <li><span class="font-semibold text-primary">Hindi:</span> Compulsory from LKG to Class X.</li>
          <li><span class="font-semibold text-primary">Sanskrit:</span> Introduced from Class VI onwards.</li>
        </ul>
        <ul class="space-y-2">
          <li><span class="font-semibold text-primary">Syllabus:</span> KG — as per Air HQ Direction; Class I–XII — CBSE guidelines.</li>
          <li><span class="font-semibold text-primary">Books:</span> KG–VIII — prescribed by Air HQ; Class IX–XII — prescribed by CBSE.</li>
        </ul>
      </div>
      <div class="mt-4 bg-yellow-50 border border-yellow-200 rounded p-3 text-sm text-gray-700">
        <strong class="text-secondary">&#9432; Note:</strong> Class XI &amp; XII is a <strong>composite course</strong>. Students who take admission to Class XI must continue with the <strong>same subject combination in Class XII</strong>.
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      <div class="lg:col-span-2 space-y-12 text-gray-700">
        
        <div>
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Curriculum Overview</h2>
          <p class="mb-4 text-justify leading-relaxed">
            Air Force School Avadi follows the curriculum prescribed by the Central Board of Secondary Education (CBSE). Our pedagogical approach is designed to foster holistic development, encourage critical thinking, and build a strong foundation in core subjects.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Pre-Primary (LKG & UKG)</h3>
              <p class="text-sm">Activity-based learning focusing on motor skills, cognitive development, and social interaction through play-way methods.</p>
            </div>
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Primary (I to V)</h3>
              <p class="text-sm">Experiential learning building foundational literacy and numeracy skills, alongside environmental awareness.</p>
            </div>
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Middle (VI to VIII)</h3>
              <p class="text-sm">Focus on conceptual clarity in Mathematics, Sciences, and Social Sciences. Three-language formula implemented.</p>
            </div>
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Secondary (IX & X)</h3>
              <p class="text-sm">Rigorous preparation for board examinations with continuous assessment and practical laboratory work.</p>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Senior Secondary Streams &amp; Subject Combinations</h2>
          <p class="mb-6 leading-relaxed">For Classes XI and XII, the school offers the following specialized streams. The table below shows the subject combinations along with internal assessment subjects.</p>

          <div class="overflow-x-auto rounded-lg shadow-sm border border-gray-200 mb-6">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-primary text-white uppercase text-xs tracking-wide">
                  <th class="p-3 text-left">Stream</th>
                  <th class="p-3 text-left">Elective Subjects</th>
                  <th class="p-3 text-left">Internal Assessment</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary align-top">Science</td>
                  <td class="p-3 text-gray-700 align-top">
                    <ul class="list-disc pl-4 space-y-1">
                      <li>English Core</li>
                      <li>Physics</li>
                      <li>Chemistry</li>
                      <li>Mathematics <span class="text-secondary font-semibold">OR</span> Biology <span class="text-gray-500">(or)</span> Informatics Practices</li>
                      <li>Computer Science / Physical Education</li>
                    </ul>
                  </td>
                  <td class="p-3 text-gray-700 align-top" rowspan="2">
                    <ul class="list-disc pl-4 space-y-1">
                      <li>Work Experience</li>
                      <li>Health and Physical Education</li>
                      <li>General Studies</li>
                    </ul>
                  </td>
                </tr>
                <tr class="hover:bg-yellow-50 transition-colors">
                  <td class="p-3 font-bold text-primary align-top">Commerce</td>
                  <td class="p-3 text-gray-700 align-top">
                    <ul class="list-disc pl-4 space-y-1">
                      <li>English Core</li>
                      <li>Accountancy</li>
                      <li>Business Studies</li>
                      <li>Economics</li>
                      <li>Informatics Practices / Mathematics</li>
                    </ul>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        {/* Academic Activities Section */}
        <div>
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Academic Activities</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {/* Senior Wing */}
            <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
              <div class="bg-primary text-white p-4">
                <h3 class="text-lg font-bold uppercase tracking-wide">Senior Wing Activities</h3>
              </div>
              <div class="p-5 text-sm text-gray-700">
                <p class="mb-4 leading-relaxed">Syllabus is divided into units and taught with modern teaching aids. Regular unit tests are conducted to assess student progress.</p>
                <ul class="list-disc pl-5 space-y-1">
                  <li>Orientation Programme</li>
                  <li>Group Discussion</li>
                  <li>Activity Based Learning</li>
                  <li>Group Study</li>
                  <li>Play Way Method</li>
                  <li>Seminar</li>
                  <li>Science Exhibition</li>
                </ul>
              </div>
            </div>
            {/* Junior Wing */}
            <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
              <div class="bg-secondary text-primary p-4">
                <h3 class="text-lg font-bold uppercase tracking-wide">Junior Wing Activities</h3>
              </div>
              <div class="p-5 text-sm text-gray-700">
                <p class="mb-4 leading-relaxed">A child-friendly environment with value-based education through theme-based activities nurtures creativity and joy of learning.</p>
                <ul class="list-disc pl-5 space-y-1">
                  <li>Fruit Day / Vegetable Day</li>
                  <li>Colour Day</li>
                  <li>Fancy Dress</li>
                  <li>Cooking Without Fire</li>
                  <li>Quiz &amp; Debate</li>
                  <li>Rangoli Making</li>
                  <li>Origami</li>
                  <li>Pencil Sketch</li>
                  <li>Festival Celebrations</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        {/* Question Papers Section */}
        <div>
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Model Question Papers</h2>
          <div class="bg-white border border-gray-200 rounded-lg p-6 flex flex-col sm:flex-row items-center gap-6 shadow-sm">
            <div class="w-full sm:w-1/3">
              <img src="/images/QuestionPaper_Model.jpg" alt="Model Question Papers" class="w-full rounded shadow" onerror="this.src='/images/logo.jpg'" />
            </div>
            <div class="w-full sm:w-2/3">
              <h3 class="text-xl font-bold text-dark mb-2">Practice for Excellence</h3>
              <p class="text-sm mb-4">Access our repository of model question papers and past board exam papers to help students prepare effectively for their upcoming assessments.</p>
              <a href="/images/QuestionPaper_Model.jpg" target="_blank" class="inline-block bg-primary text-white font-bold py-2 px-6 rounded hover:bg-primary-dark transition-colors text-sm uppercase">View Model Papers</a>
            </div>
          </div>
        </div>

        {/* News in Education & Virtual Classroom */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white border-l-4 border-secondary rounded-lg shadow-sm p-5">
            <h3 class="text-lg font-bold text-primary mb-2 uppercase">News in Education</h3>
            <p class="text-sm text-gray-700 leading-relaxed">The school is associated with the <strong>Times of India — Student Edition</strong> to develop reading habits and general awareness among students through regular newspaper engagement.</p>
          </div>
          <div class="bg-white border-l-4 border-primary rounded-lg shadow-sm p-5">
            <h3 class="text-lg font-bold text-primary mb-2 uppercase">Virtual Classroom</h3>
            <p class="text-sm text-gray-700 leading-relaxed">The school is equipped with <strong>Smart Boards</strong> and <strong>E-Learning infrastructure</strong> in every classroom, enabling interactive and engaging digital education for all students.</p>
          </div>
        </div>

      </div>
      
      {/* Sidebar */}
      <div class="space-y-8">
        
        {/* Academic Calendar — HTML Table */}
        <div id="calendar" class="bg-white border-2 border-gray-200 rounded-lg shadow-md overflow-hidden">
          <div class="bg-primary text-white p-4 text-center">
             <h3 class="text-xl font-bold uppercase tracking-wide flex items-center justify-center gap-2">
               <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
               Academic Calendar 2025-26
             </h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-100 text-primary uppercase text-xs tracking-wide border-b-2 border-gray-300">
                  <th class="p-3 text-left">Month</th>
                  <th class="p-3 text-left">Key Events / Examinations</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">April</td>
                  <td class="p-3 text-gray-700">New Academic Session begins · Unit Test 1 (Classes I–VIII)</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">May</td>
                  <td class="p-3 text-gray-700">Half-Yearly Exam Preparation · Summer Vacation (approx.)</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">June</td>
                  <td class="p-3 text-gray-700">School Re-opens after Summer Break</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">July</td>
                  <td class="p-3 text-gray-700">Unit Test 2 · PTM (Parent-Teacher Meeting)</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">August</td>
                  <td class="p-3 text-gray-700">Independence Day celebrations · NCC/Scouts activities</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">September</td>
                  <td class="p-3 text-gray-700">Half-Yearly Examinations (Classes I–XII)</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">October</td>
                  <td class="p-3 text-gray-700">Half-Yearly results · Dussehra Holidays · Unit Test 3</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">November</td>
                  <td class="p-3 text-gray-700">Annual Sports Day · Cultural Events · PTM</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">December</td>
                  <td class="p-3 text-gray-700">Annual Day · Pre-Board Exams begin (Class X & XII) · Winter Vacation</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">January</td>
                  <td class="p-3 text-gray-700">Republic Day · CBSE Pre-Board / Practical Exams</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">February</td>
                  <td class="p-3 text-gray-700">CBSE Board Exams begin (Class X & XII) · Annual Exam for other classes</td>
                </tr>
                <tr class="hover:bg-blue-50 transition-colors">
                  <td class="p-3 font-bold text-primary">March</td>
                  <td class="p-3 text-gray-700">CBSE Board Exams conclude · Annual Exam Results · Academic Session ends</td>
                </tr>
              </tbody>
            </table>
          </div>
          <div class="p-3 bg-gray-50 border-t border-gray-200">
            <a href="/images/Academic Calender_25.jpg" target="_blank" rel="noopener noreferrer" class="text-xs text-primary underline hover:text-accent transition-colors">
              View official Academic Calendar image ↗
            </a>
          </div>
        </div>

        {/* Curriculum Documents */}
        <div id="papers" class="bg-gray-50 border border-gray-200 rounded-lg p-6 shadow-sm">
          <h3 class="text-xl font-bold text-primary mb-4 uppercase border-b border-gray-300 pb-2">Academic Stats</h3>
          <ul class="space-y-4">
            <li class="flex items-center justify-between">
              <span class="font-semibold text-gray-600">Student-Teacher Ratio</span>
              <span class="font-bold text-secondary text-lg">25:1</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="font-semibold text-gray-600">Smart Classrooms</span>
              <span class="font-bold text-secondary text-lg">100%</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="font-semibold text-gray-600">Well-equipped Labs</span>
              <span class="font-bold text-secondary text-lg">4</span>
            </li>
          </ul>
        </div>

        {/* Sample Question Papers */}
        <div class="bg-primary text-white rounded-lg p-6 shadow-md border-t-4 border-secondary">
          <h3 class="text-lg font-bold mb-4 uppercase tracking-wide border-b border-white/20 pb-2">Sample Question Papers</h3>
          <p class="text-sm text-white/80 mb-4">Access model question papers for CBSE Board examination preparation.</p>
          <ul class="space-y-2">
            <li>
              <a href="/images/QuestionPaper_Model.jpg" target="_blank" rel="noopener noreferrer" class="flex items-center text-sm text-white hover:text-secondary transition-colors">
                <svg class="w-4 h-4 mr-2 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Model Question Papers
              </a>
            </li>
            <li>
              <a href="/achievements#results" class="flex items-center text-sm text-white hover:text-secondary transition-colors">
                <svg class="w-4 h-4 mr-2 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                Board Exam Results
              </a>
            </li>
            <li>
              <a href="https://cbseacademic.nic.in/" target="_blank" rel="noopener noreferrer" class="flex items-center text-sm text-white hover:text-secondary transition-colors">
                <svg class="w-4 h-4 mr-2 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                CBSE Academic Website ↗
              </a>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </section>
</Layout>
