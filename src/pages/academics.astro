---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Academics">
  <div class="bg-primary text-white py-16 border-b-4 border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-extrabold uppercase tracking-wide">Academics</h1>
      <p class="text-gray-300 mt-2 font-medium">Curriculum, Streams, and Calendar</p>
    </div>
  </div>

  <section class="py-12 md:py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      <div class="lg:col-span-2 space-y-12 text-gray-700">
        
        <div>
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Curriculum Overview</h2>
          <p class="mb-4 text-justify leading-relaxed">
            Air Force School Avadi follows the curriculum prescribed by the Central Board of Secondary Education (CBSE). Our pedagogical approach is designed to foster holistic development, encourage critical thinking, and build a strong foundation in core subjects.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Pre-Primary (LKG & UKG)</h3>
              <p class="text-sm">Activity-based learning focusing on motor skills, cognitive development, and social interaction through play-way methods.</p>
            </div>
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Primary (I to V)</h3>
              <p class="text-sm">Experiential learning building foundational literacy and numeracy skills, alongside environmental awareness.</p>
            </div>
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Middle (VI to VIII)</h3>
              <p class="text-sm">Focus on conceptual clarity in Mathematics, Sciences, and Social Sciences. Three-language formula implemented.</p>
            </div>
            <div class="border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
              <h3 class="text-xl font-bold text-secondary uppercase mb-3 border-b border-gray-100 pb-2">Secondary (IX & X)</h3>
              <p class="text-sm">Rigorous preparation for board examinations with continuous assessment and practical laboratory work.</p>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Senior Secondary Streams</h2>
          <p class="mb-6 leading-relaxed">For Classes XI and XII, the school offers the following specialized streams:</p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg shadow-sm">
              <h3 class="text-xl font-bold text-primary mb-3 uppercase flex items-center">
                 <svg class="w-6 h-6 mr-2 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                 Science Stream
              </h3>
              <ul class="list-disc pl-5 space-y-2 text-dark font-medium">
                <li>English Core</li>
                <li>Physics</li>
                <li>Chemistry</li>
                <li>Mathematics / Biology</li>
                <li>Computer Science / Physical Education</li>
              </ul>
            </div>
            
            <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg shadow-sm">
              <h3 class="text-xl font-bold text-primary mb-3 uppercase flex items-center">
                 <svg class="w-6 h-6 mr-2 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                 Commerce Stream
              </h3>
              <ul class="list-disc pl-5 space-y-2 text-dark font-medium">
                <li>English Core</li>
                <li>Accountancy</li>
                <li>Business Studies</li>
                <li>Economics</li>
                <li>Informatics Practices / Mathematics</li>
              </ul>
            </div>
          </div>
        </div>

        {/* Question Papers Section */}
        <div>
          <h2 class="text-3xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Model Question Papers</h2>
          <div class="bg-white border border-gray-200 rounded-lg p-6 flex flex-col sm:flex-row items-center gap-6 shadow-sm">
            <div class="w-full sm:w-1/3">
              <img src="/images/QuestionPaper_Model.jpg" alt="Model Question Papers" class="w-full rounded shadow" onerror="this.src='/images/logo.jpg'" />
            </div>
            <div class="w-full sm:w-2/3">
              <h3 class="text-xl font-bold text-dark mb-2">Practice for Excellence</h3>
              <p class="text-sm mb-4">Access our repository of model question papers and past board exam papers to help students prepare effectively for their upcoming assessments.</p>
              <a href="/images/QuestionPaper_Model.jpg" target="_blank" class="inline-block bg-primary text-white font-bold py-2 px-6 rounded hover:bg-primary-dark transition-colors text-sm uppercase">View Model Papers</a>
            </div>
          </div>
        </div>

      </div>
      
      {/* Sidebar */}
      <div class="space-y-8">
        
        {/* Academic Calendar */}
        <div class="bg-white border-2 border-gray-200 rounded-lg shadow-md overflow-hidden">
          <div class="bg-primary text-white p-4 text-center">
             <h3 class="text-xl font-bold uppercase tracking-wide">Academic Calendar</h3>
          </div>
          <div class="p-4">
             <a href="/images/Academic Calender_25.jpg" target="_blank" class="block group">
               <img src="/images/Academic Calender_25.jpg" alt="Academic Calendar 2025" class="w-full h-auto border border-gray-200 group-hover:opacity-90 transition-opacity" />
               <div class="mt-4 text-center">
                 <span class="inline-block bg-gray-100 text-primary font-bold px-4 py-2 rounded group-hover:bg-gray-200 transition-colors border border-gray-300 w-full">View Full Size</span>
               </div>
             </a>
          </div>
        </div>

        {/* Key Statistics */}
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 shadow-sm">
          <h3 class="text-xl font-bold text-primary mb-4 uppercase border-b border-gray-300 pb-2">Academic Stats</h3>
          <ul class="space-y-4">
            <li class="flex items-center justify-between">
              <span class="font-semibold text-gray-600">Student-Teacher Ratio</span>
              <span class="font-bold text-secondary text-lg">25:1</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="font-semibold text-gray-600">Smart Classrooms</span>
              <span class="font-bold text-secondary text-lg">100%</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="font-semibold text-gray-600">Well-equipped Labs</span>
              <span class="font-bold text-secondary text-lg">4</span>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </section>
</Layout>
