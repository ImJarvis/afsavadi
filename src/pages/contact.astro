---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">
  <div class="bg-primary text-white py-16 border-b-4 border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-extrabold uppercase tracking-wide">Contact Us</h1>
      <p class="text-gray-300 mt-2 font-medium">We are here to help and answer any questions you might have.</p>
    </div>
  </div>

  <section class="py-12 md:py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      
      {/* Contact Details & Form */}
      <div class="space-y-12">
        <div>
          <h2 class="text-2xl font-bold text-primary mb-6 border-b-2 border-secondary pb-2 inline-block uppercase">Get in Touch</h2>
          <p class="text-gray-600 mb-8">We welcome your inquiries. Please feel free to reach out to the school administration using the contact details below or fill out the form.</p>
          
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="bg-blue-50 p-4 rounded-full text-primary border border-blue-100 mr-4 shrink-0 shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div>
                <h3 class="font-bold text-dark uppercase tracking-wide text-sm">Address</h3>
                <p class="text-gray-600 mt-1">Air Force School, 23 Equipment Depot,<br/>Air Force Station Avadi,<br/>Chennai – 600055</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-blue-50 p-4 rounded-full text-primary border border-blue-100 mr-4 shrink-0 shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <h3 class="font-bold text-dark uppercase tracking-wide text-sm">Phone Number</h3>
                <p class="text-gray-600 mt-1 font-medium">044 26840017</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-blue-50 p-4 rounded-full text-primary border border-blue-100 mr-4 shrink-0 shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <h3 class="font-bold text-dark uppercase tracking-wide text-sm">Email</h3>
                <p class="text-gray-600 mt-1 font-medium"><a href="mailto:afschoolavadi@gmail.com" class="hover:text-primary transition-colors">afschoolavadi@gmail.com</a></p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="bg-blue-50 p-4 rounded-full text-primary border border-blue-100 mr-4 shrink-0 shadow-sm">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div>
                <h3 class="font-bold text-dark uppercase tracking-wide text-sm">Office Hours</h3>
                <p class="text-gray-600 mt-1">Monday - Friday: 08:30 AM to 02:30 PM<br/>Saturday & Sunday: Closed</p>
              </div>
            </div>
          </div>
        </div>

        {/* Contact Form */}
        <div class="bg-white p-8 rounded-lg shadow-md border border-gray-200">
          <h3 class="text-xl font-bold text-primary mb-6 uppercase">Send us a Message</h3>
          <p class="text-sm text-gray-500 mb-4">Fill in the form below and we will get back to you within 1-2 working days.</p>
          {/* Formspree form — replace YOUR_FORM_ID with actual Formspree endpoint ID from formspree.io */}
          <form
            id="contact-form"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            class="space-y-4"
          >
            {/* Honeypot spam protection */}
            <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Full Name</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow" placeholder="Your Name" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email Address</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow" placeholder="your@email.com" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-semibold text-gray-700 mb-1">Subject</label>
              <input type="text" id="subject" name="subject" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow" placeholder="How can we help?" />
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">Message</label>
              <textarea id="message" name="message" rows="4" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow" placeholder="Your message here..."></textarea>
            </div>
            <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-3 px-6 rounded uppercase tracking-wide transition-colors flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              Send Message
            </button>
          </form>
          <p class="text-xs text-gray-400 mt-3 text-center">
            ⚠️ <strong>Admin Note:</strong> Replace <code class="bg-gray-100 px-1 rounded">YOUR_FORM_ID</code> in the form action with your <a href="https://formspree.io" target="_blank" rel="noopener noreferrer" class="text-primary underline">Formspree.io</a> endpoint ID to activate this form.
          </p>
        </div>
      </div>

      {/* Map Embed */}
      <div class="h-[600px] rounded-lg overflow-hidden shadow-md border border-gray-200 sticky top-32">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3886.136894059039!2d80.10011507519965!3d13.119036587210986!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a5261173ea3db6b%3A0x6339031efb702ec2!2sAir%20Force%20School%20Avadi!5e0!3m2!1sen!2sin!4v1709214562013!5m2!1sen!2sin" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>
  </section>
</Layout>
