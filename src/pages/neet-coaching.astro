---
import Layout from '../layouts/Layout.astro';
---

<Layout title="NEET & JEE Coaching | Air Force School Avadi">

  {/* Page Banner */}
  <div class="bg-primary text-white py-16 border-b-4 border-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
        <span class="inline-flex items-center bg-secondary text-primary text-xs font-extrabold uppercase tracking-widest px-3 py-1 rounded-full w-fit">
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
          </svg>
          New Programme
        </span>
      </div>
      <h1 class="text-3xl md:text-5xl font-extrabold uppercase tracking-wide">NEET &amp; JEE Coaching</h1>
      <p class="text-gray-300 mt-2 font-medium max-w-2xl">Step into Excellence — Integrated coaching for competitive entrance examinations alongside CBSE curriculum</p>
    </div>
  </div>

  {/* Main Content */}
  <section class="py-12 md:py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      {/* Left Column */}
      <div class="space-y-8">

        {/* Description */}
        <div>
          <h2 class="text-2xl font-bold text-primary mb-4 border-b-2 border-secondary pb-2 uppercase inline-block">About the Programme</h2>
          <p class="text-gray-700 leading-relaxed mb-4 text-justify">
            Air Force School Avadi is proud to launch an integrated NEET &amp; JEE coaching programme designed to prepare students for India's most prestigious medical and engineering entrance examinations — all while seamlessly continuing their CBSE board curriculum.
          </p>
          <p class="text-gray-700 leading-relaxed text-justify">
            Our expert faculty, state-of-the-art ATAL Tinkering Lab, and smart board-enabled classrooms create an environment where scientific thinking flourishes. Students get the best of both worlds: rigorous entrance exam preparation and a strong foundation in CBSE academics.
          </p>
        </div>

        {/* Feature Cards */}
        <div class="space-y-4">
          {/* Card 1 */}
          <div class="flex items-start gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex-shrink-0 w-12 h-12 bg-primary rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-primary uppercase text-sm tracking-wide mb-1">Focused Coaching</h3>
              <p class="text-gray-600 text-sm leading-relaxed">Dedicated sessions for NEET (Biology, Physics, Chemistry) and JEE (Mathematics, Physics, Chemistry) by experienced faculty who understand the competitive exam landscape.</p>
            </div>
          </div>

          {/* Card 2 */}
          <div class="flex items-start gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex-shrink-0 w-12 h-12 bg-primary rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-primary uppercase text-sm tracking-wide mb-1">Practice &amp; Mock Tests</h3>
              <p class="text-gray-600 text-sm leading-relaxed">Regular mock tests modelled on actual NEET and JEE patterns, with detailed performance analysis to identify strengths and areas for improvement.</p>
            </div>
          </div>

          {/* Card 3 */}
          <div class="flex items-start gap-4 bg-white border border-gray-200 rounded-lg p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex-shrink-0 w-12 h-12 bg-primary rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-primary uppercase text-sm tracking-wide mb-1">Integrated with CBSE</h3>
              <p class="text-gray-600 text-sm leading-relaxed">Coaching is structured to complement the CBSE curriculum, so students excel in board exams while simultaneously preparing for NEET or JEE.</p>
            </div>
          </div>
        </div>

        {/* CTA Button */}
        <div class="pt-4">
          <a
            href="https://forms.gle/sJd8W2R854hF7n6VA"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center bg-secondary hover:bg-amber-400 text-primary font-bold uppercase tracking-wide px-8 py-4 rounded-lg shadow-md hover:shadow-lg transition-all text-base group"
          >
            <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Register for NEET/JEE Programme
          </a>
          <p class="text-xs text-gray-500 mt-2">Registration via Google Form. Limited seats available — apply early.</p>
        </div>

      </div>

      {/* Right Column — Programme Highlights Card */}
      <div>
        <div class="bg-gradient-to-br from-primary to-blue-900 text-white rounded-xl shadow-xl overflow-hidden">

          <div class="bg-secondary px-6 py-4">
            <h2 class="text-primary font-extrabold uppercase text-lg tracking-wide flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Programme Highlights
            </h2>
          </div>

          <div class="px-6 py-6 space-y-4">
            {/* Highlight items */}
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-secondary flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-200 text-sm leading-relaxed">Available for <strong class="text-white">Class XI &amp; XII Science</strong> students</p>
            </div>

            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-secondary flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-200 text-sm leading-relaxed">Comprehensive coverage of <strong class="text-white">Physics, Chemistry, Maths &amp; Biology</strong></p>
            </div>

            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-secondary flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-200 text-sm leading-relaxed"><strong class="text-white">Expert and experienced faculty</strong> with a strong track record in competitive exam coaching</p>
            </div>

            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-secondary flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-200 text-sm leading-relaxed"><strong class="text-white">ATAL Tinkering Lab</strong> for hands-on practical learning and scientific experimentation</p>
            </div>

            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-secondary flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-200 text-sm leading-relaxed"><strong class="text-white">Smart board enabled classrooms</strong> for interactive and engaging learning sessions</p>
            </div>

            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-red-400 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <p class="text-gray-200 text-sm leading-relaxed"><strong class="text-white">Limited seats</strong> — early registration is strongly recommended to secure your place</p>
            </div>
          </div>

          {/* Divider */}
          <div class="mx-6 border-t border-white border-opacity-20"></div>

          {/* Contact Info Block */}
          <div class="px-6 py-5">
            <h3 class="text-secondary font-bold uppercase text-xs tracking-widest mb-3">Contact for Enquiries</h3>
            <div class="space-y-2">
              <a href="tel:04426840017" class="flex items-center gap-2 text-gray-200 hover:text-white text-sm transition-colors group">
                <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <span class="group-hover:underline">044 26840017 / 044 26842045</span>
              </a>
              <a href="mailto:afschoolavadi@gmail.com" class="flex items-center gap-2 text-gray-200 hover:text-white text-sm transition-colors group">
                <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <span class="group-hover:underline">afschoolavadi@gmail.com</span>
              </a>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

</Layout>
