---
import Layout from '../layouts/Layout.astro';

// Dummy data for notices - in a real site this would come from a CMS or markdown files
const notices = [
  { id: 1, date: "2026-06-01", title: "Admissions Open for Academic Year", isNew: true },
  { id: 2, date: "2026-05-15", title: "Summer Vacation Schedule Announced", isNew: false },
  { id: 3, date: "2026-04-10", title: "CBSE Board Exam Results Declaration", isNew: false },
  { id: 4, date: "2026-03-20", title: "Revised Fee Structure for New Session", isNew: false },
];
---

<Layout title="Notices & Circulars">
  <div class="bg-primary text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold">Notices & Circulars</h1>
    </div>
  </div>

  <section class="py-12 md:py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <ul class="divide-y divide-gray-200">
        {notices.map((notice) => (
          <li class="p-6 hover:bg-gray-50 transition-colors flex flex-col md:flex-row md:items-center justify-between group">
            <div class="flex items-start md:items-center mb-4 md:mb-0">
              <div class="bg-blue-100 text-primary px-3 py-1 rounded text-sm font-bold mr-4 shrink-0">
                {new Date(notice.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}
              </div>
              <div>
                <h3 class="text-lg font-medium text-dark group-hover:text-primary transition-colors flex items-center">
                  {notice.title}
                  {notice.isNew && <span class="ml-3 bg-red-500 text-white text-xs px-2 py-0.5 rounded-full uppercase tracking-wider animate-pulse">New</span>}
                </h3>
              </div>
            </div>
            <button class="text-primary hover:text-secondary font-medium text-sm flex items-center self-start md:self-auto transition-colors">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              Download PDF
            </button>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
